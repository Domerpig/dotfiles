[
    {
        "position": "top",
        "layer": "top",
        "output": "Acer Technologies VG270U P 0x912094FE",
        "height": 20,
        "modules-left": [
            "river/tags"
        ],
        "modules-center": [
            "custom/spotify"
        ],
        "modules-right": [
            "custom/xbps",
            "memory",
            "cpu",
            "custom/weather",
            "clock"
        ],
        "clock": {
            "interval": 10,
            "format": "<span color='#FF9E64'>󰃰</span> {:%H:%M}",
            "tooltip-format": "<tt><small>{calendar}</small></tt>",
            "calendar": {
                "mode": "month",
                "on-scroll": 1,
                "weeks-pos": "left",
                "format": {
                    "months": "<span color='#E6C384'><b>{}</b></span>",
                    "days": "<span color='#DCD7BA'><b>{}</b></span>",
                    "weeks": "<span color='#7E9CD8'><b>W{}</b></span>",
                    "weekdays": "<span color='#7AA89F'><b>{}</b></span>",
                    "today": "<span color='#98BB6C'><b><u>{}</u></b></span>"
                }
            },
            "actions": {
                "on-scroll-down": "shift_up",
                "on-scroll-up": "shift_down"
            }
        },
        "cpu": {
            "format": "<span color ='#98BB6C'></span>  {usage}%",
            "interval": 3
        },
        "memory": {
            "format": "<span color ='#D27E99'></span>  {used}GB |"
        },
        "sway/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "5": ""
            }
        },
        "wireplumber": {
            "format": "{volume}%",
            "format-muted": "",
            "on-click": "helvum",
            "max-volume": 150,
            "scroll-step": 0.2
        },
        "custom/spotify": {
            "format": "<span color = '#1DB954'></span> {}",
            "max-length": 60,
            "exec": "$HOME/.config/waybar/scripts/spotify.sh",
            "exec-if": "pgrep spotify",
            "interval": 1,
            "escape": true,
            "on-click": "playerctl play-pause"
        },
        "tray": {
            "show-passive-items": true
        },
        "river/tags": {
            "num-tags": 5
        },
        "custom/xbps": {
            "format": "{} ",
            "return-type": "json",
            "tooltip": true,
            "exec": "~/.config/waybar/scripts/xbps-updates.sh",
            "signal": 4
        },
        "custom/weather": {
            "exec": "${HOME}/.config/waybar/scripts/weather.sh Andernach",
            "return-type": "json",
            "format": "{icon} {} |",
            "format-icons": [
                "<span color = '#DCD7BA'></span>",
                "<span color = '#A3D4D5'></span>",
                "<span color = '#98BB6C'></span>",
                "<span color = '#FFA066'></span>",
                "<span color = '#E46876'></span>"
            ],
            "tooltip": true,
            "interval": 600
        }
    },
    {
        "position": "top",
        "layer": "top",
        "output": "Acer Technologies VG270 TEGEE0018512",
        "height": 18,
        "modules-right": [
            "river/tags"
        ],
        "river/tags": {
            "num-tags": 5
        }
    },
    {
        "position": "top",
        "layer": "top",
        "output": "AOC 2470W GGJGCHA013780",
        "height": 18,
        "modules-left": [
            "river/tags"
        ],
        "river/tags": {
            "num-tags": 5
        }
    }
]
