[
    {
        "position": "top",
        "layer": "top",
        "output": "Acer Technologies VG270U P 0x912094FE",
        "height": 20,
        "modules-left": [
            "river/tags"
        ],
        "modules-center": [
            "custom/spotify"
        ],
        "modules-right": [
            "memory",
            "cpu",
            "clock",
            "custom/powermenu"
        ],
        "clock": {
            "interval": 10,
            "format": "<span color ='#d99a5e'>󰃰</span> {:%H:%M} |",
            "tooltip-format": "<tt><small>{calendar}</small></tt>",
            "calendar": {
                "mode": "month",
                "on-scroll": 1,
                "weeks-pos": "left",
                "format": {
                    "months": "<span color='#a9b1d6'><b>{}</b></span>",
                    "days": "<span color='#c0caf5'><b>{}</b></span>",
                    "weeks": "<span color='#719cd6'><b>W{}</b></span>",
                    "weekdays": "<span color='#7dcfff'><b>{}</b></span>",
                    "today": "<span color='#97ca72'><b><u>{}</u></b></span>"
                }
            },
            "actions": {
                "on-scroll-down": "shift_up",
                "on-scroll-up": "shift_down"
            }
        },
        "cpu": {
            "format": "<span color ='#97ca72'></span>  {usage}%",
            "interval": 3
        },
        "memory": {
            "format": "<span color ='#ca72e4'></span>  {percentage}% |"
        },
        "sway/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "5": ""
            }
        },
        "custom/powermenu": {
            "format": "<span color ='#ef5f6b'>⏻</span>",
            "on-click": "~/.config/rofi/powermenu/type-1/powermenu.sh"
        },
        "wireplumber": {
            "format": "{volume}%",
            "format-muted": "",
            "on-click": "helvum",
            "max-volume": 150,
            "scroll-step": 0.2
        },
        "custom/spotify": {
            "format": "<span color = '#1DB954'></span> {}",
            "max-length": 50,
            "exec": "$HOME/.config/waybar/scripts/spotify.sh",
            "exec-if": "pgrep spotify",
            "interval": 1,
            "escape": true,
            "on-click": "playerctl play-pause"
        },
        "tray": {
            "show-passive-items": true
        },
        "river/tags": {
            "num-tags": 5
        }
    },
    {
        "position": "top",
        "layer": "top",
        "output": "Acer Technologies VG270 TEGEE0018512",
        "height": 18,
        "modules-right": [
            "river/tags"
        ],
        "river/tags": {
            "num-tags": 5
        }
    },
    {
        "position": "top",
        "layer": "top",
        "output": "AOC 2470W GGJGCHA013780",
        "height": 18,
        "modules-left": [
            "river/tags"
        ],
        "river/tags": {
            "num-tags": 5
        }
    }
]
